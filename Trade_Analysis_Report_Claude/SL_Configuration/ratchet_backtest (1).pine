//@version=6
strategy(title="Ratchet SL Backtest", overlay=true, initial_capital=1000, default_qty_type=strategy.percent_of_equity, default_qty_value=100, commission_type=strategy.commission.percent, commission_value=0.05, slippage=1, pyramiding=1)

// ── Inputs ────────────────────────────────────────────────────────────────────
i_entry    = input.float(0.174,  "Entry Price (mid)",  group="Signal")
i_sl       = input.float(0.186,  "Stop Loss Price",    group="Signal")
i_dir      = input.string("Short", "Direction", options=["Long","Short"], group="Signal")
i_max_bars = input.int(720, "Max bars to hold (1H)", group="Signal", minval=1)

i_tp1  = input.float(0.0, "TP1",  group="Take Profits")
i_tp2  = input.float(0.0, "TP2",  group="Take Profits")
i_tp3  = input.float(0.0, "TP3",  group="Take Profits")
i_tp4  = input.float(0.0, "TP4",  group="Take Profits")
i_tp5  = input.float(0.0, "TP5",  group="Take Profits")
i_tp6  = input.float(0.0, "TP6",  group="Take Profits")
i_tp7  = input.float(0.0, "TP7",  group="Take Profits")
i_tp8  = input.float(0.0, "TP8",  group="Take Profits")
i_tp9  = input.float(0.0, "TP9",  group="Take Profits")
i_tp10 = input.float(0.0, "TP10", group="Take Profits")

i_ratchet = input.string("Standard", "Ratchet Mode", options=["Standard","Skip TP2","BE only","No ratchet"], group="Strategy")
i_alloc   = input.string("Bot default", "TP Allocation", options=["Equal","Bot default","Front loaded"], group="Strategy")
i_labels  = input.bool(true, "Show labels",   group="Display")
i_shade   = input.bool(true, "Shade window",  group="Display")

// ── TP array (built once) ─────────────────────────────────────────────────────
var float[] tps = array.new_float(0)
if barstate.isfirst
    if i_tp1  > 0
        array.push(tps, i_tp1)
    if i_tp2  > 0
        array.push(tps, i_tp2)
    if i_tp3  > 0
        array.push(tps, i_tp3)
    if i_tp4  > 0
        array.push(tps, i_tp4)
    if i_tp5  > 0
        array.push(tps, i_tp5)
    if i_tp6  > 0
        array.push(tps, i_tp6)
    if i_tp7  > 0
        array.push(tps, i_tp7)
    if i_tp8  > 0
        array.push(tps, i_tp8)
    if i_tp9  > 0
        array.push(tps, i_tp9)
    if i_tp10 > 0
        array.push(tps, i_tp10)

n_tps  = array.size(tps)
is_long = i_dir == "Long"

// ── Allocation weight ─────────────────────────────────────────────────────────
get_weight(idx, n) =>
    float w = 1.0 / n
    if i_alloc == "Bot default"
        if n == 5
            float[] d = array.from(0.10, 0.12, 0.18, 0.25, 0.35)
            w := array.get(d, idx)
        else if n == 6
            float[] d = array.from(0.05, 0.07, 0.10, 0.15, 0.25, 0.38)
            w := array.get(d, idx)
        else if n == 7
            float[] d = array.from(0.04, 0.05, 0.07, 0.10, 0.15, 0.25, 0.34)
            w := array.get(d, idx)
        else if n == 8
            float[] d = array.from(0.03, 0.04, 0.05, 0.07, 0.10, 0.16, 0.25, 0.30)
            w := array.get(d, idx)
    else if i_alloc == "Front loaded"
        float total = 0.0
        for j = 0 to n - 1
            total := total + float(n - j)
        w := float(n - idx) / total
    w

// ── State ─────────────────────────────────────────────────────────────────────
var bool  in_trade    = false
var bool  trade_done  = false
var bool  entry_fired = false
var float entry_px    = na
var float cur_sl      = na
var float risk_r      = na
var int   entry_bar   = na
var float realised    = 0.0
var float remaining   = 1.0
var int   high_tp     = 0
var int   close_rsn   = 0
var bool[] tp_hit     = array.new_bool(10, false)

// ── Entry inputs: explicit calendar fields (unambiguous across years) ────────
i_year  = input.int(2025, "Signal Year",  group="Signal", minval=2020, maxval=2030)
i_month = input.int(3,    "Signal Month", group="Signal", minval=1, maxval=12)
i_day   = input.int(30,   "Signal Day",   group="Signal", minval=1, maxval=31)
i_hour  = input.int(23,   "Signal Hour",  group="Signal", minval=0, maxval=23)

// Match exact calendar date — immune to timestamp ambiguity across years
is_signal_bar = year == i_year and month == i_month and dayofmonth == i_day and hour == i_hour

if is_signal_bar and strategy.opentrades == 0 and strategy.closedtrades == 0 and i_entry > 0.0 and n_tps > 0
    entry_fired := true
    in_trade    := true
    entry_bar   := bar_index
    entry_px    := i_entry
    cur_sl      := i_sl
    risk_r      := math.abs(i_entry - i_sl)
    high_tp     := 0
    remaining   := 1.0
    realised    := 0.0
    close_rsn   := 0
    for k = 0 to 9
        array.set(tp_hit, k, false)
    strategy.entry("T", is_long ? strategy.long : strategy.short, comment="Entry")

// ── Recover state if Pine reset vars but trade is still open ─────────────────
if strategy.opentrades > 0 and na(entry_px)
    entry_px  := i_entry
    cur_sl    := i_sl
    risk_r    := math.abs(i_entry - i_sl)
    remaining := 1.0
    realised  := 0.0

// ── Active trade management ───────────────────────────────────────────────────
if strategy.opentrades > 0 and not trade_done and risk_r > 0.0

    bars_in = bar_index - entry_bar

    // Check each TP in order
    for i = 0 to n_tps - 1
        if not array.get(tp_hit, i)
            tp_px   = array.get(tps, i)
            touched = is_long ? high >= tp_px : low <= tp_px
            if touched
                array.set(tp_hit, i, true)
                high_tp  := i + 1
                alloc     = get_weight(i, n_tps)
                tp_rr     = math.abs(tp_px - entry_px) / risk_r
                realised := realised + alloc * tp_rr
                remaining := remaining - alloc

                // Ratchet SL
                if i_ratchet == "Standard"
                    cur_sl := i == 0 ? entry_px : array.get(tps, i - 1)
                else if i_ratchet == "Skip TP2"
                    if i == 0
                        cur_sl := entry_px
                    else if i >= 2
                        cur_sl := array.get(tps, i - 1)
                else if i_ratchet == "BE only"
                    if i == 0
                        cur_sl := entry_px
                // "No ratchet" → cur_sl stays at i_sl

                if i_labels
                    label.new(bar_index, tp_px, "TP" + str.tostring(i + 1) + " ✓", color=color.new(color.green, 15), textcolor=color.white, size=size.small, style=label.style_label_down)

    // SL check
    sl_hit = is_long ? low <= cur_sl : high >= cur_sl

    if sl_hit and not trade_done
        if high_tp == 0
            realised := -1.0
        else
            sl_rr     = math.abs(cur_sl - entry_px) / risk_r
            realised := realised + remaining * sl_rr
        close_rsn := 1
        trade_done := true
        in_trade   := false
        strategy.close("T", comment=high_tp == 0 ? "SL" : "Ratchet SL TP" + str.tostring(high_tp))
        if i_labels
            lbl = high_tp == 0 ? "SL ✗" : "Ratchet SL after TP" + str.tostring(high_tp)
            label.new(bar_index, cur_sl, lbl, color=color.new(high_tp == 0 ? color.red : color.orange, 15), textcolor=color.white, size=size.small, style=label.style_label_up)

    // All TPs hit
    if remaining <= 0.001 and not trade_done
        close_rsn  := 2
        trade_done := true
        in_trade   := false
        strategy.close("T", comment="All TPs hit")

    // Timeout
    if bars_in >= i_max_bars and not trade_done
        to_rr      = (close - entry_px) * (is_long ? 1.0 : -1.0) / risk_r
        realised  := realised + remaining * to_rr
        close_rsn  := 3
        trade_done := true
        in_trade   := false
        strategy.close("T", comment="Timeout")
        if i_labels
            label.new(bar_index, close, "Timeout", color=color.new(color.gray, 15), textcolor=color.white, size=size.small, style=label.style_label_down)

// ── Visuals ───────────────────────────────────────────────────────────────────
active = strategy.opentrades > 0 or trade_done
plot(active ? cur_sl   : na, "SL",    color=color.red,  linewidth=1, style=plot.style_linebr)
plot(active ? entry_px : na, "Entry", color=color.blue, linewidth=1, style=plot.style_linebr)

bgcolor(i_shade and strategy.opentrades > 0 ? color.new(color.blue, 93) : na)

if i_labels and strategy.opentrades > 0
    for i = 0 to n_tps - 1
        tp_px   = array.get(tps, i)
        already = array.get(tp_hit, i)
        line.new(bar_index - 1, tp_px, bar_index, tp_px, color=already ? color.new(color.green, 60) : color.new(color.green, 20), style=line.style_dashed, width=1)

// ── Results table ─────────────────────────────────────────────────────────────
var table tbl = table.new(position.top_right, 2, 13, bgcolor=color.new(color.black, 75), border_color=color.new(color.gray, 40), border_width=1, frame_color=color.new(color.gray, 20), frame_width=1)

rsn_str(r) =>
    r == 1 ? "SL / Ratchet SL" : r == 2 ? "All TPs hit ✓" : r == 3 ? "Timeout" : "In progress"

if active
    pnl_col = realised >= 0.0 ? color.lime : color.red
    dir_col = is_long ? color.lime : color.red
    table.cell(tbl, 0, 0,  "RATCHET BACKTEST",  bgcolor=color.new(color.navy, 20), text_color=color.white,  text_size=size.small)
    table.cell(tbl, 1, 0,  syminfo.ticker,       bgcolor=color.new(color.navy, 20), text_color=color.yellow, text_size=size.small)
    table.cell(tbl, 0, 1,  "Mode",               text_color=color.silver, text_size=size.tiny)
    table.cell(tbl, 1, 1,  i_ratchet,            text_color=color.white,  text_size=size.tiny)
    table.cell(tbl, 0, 2,  "Allocation",         text_color=color.silver, text_size=size.tiny)
    table.cell(tbl, 1, 2,  i_alloc,              text_color=color.white,  text_size=size.tiny)
    table.cell(tbl, 0, 3,  "Direction",          text_color=color.silver, text_size=size.tiny)
    table.cell(tbl, 1, 3,  i_dir,                text_color=dir_col,      text_size=size.tiny)
    table.cell(tbl, 0, 4,  "Entry",              text_color=color.silver, text_size=size.tiny)
    table.cell(tbl, 1, 4,  str.tostring(entry_px, "#.######"), text_color=color.white, text_size=size.tiny)
    table.cell(tbl, 0, 5,  "Stop Loss",          text_color=color.silver, text_size=size.tiny)
    table.cell(tbl, 1, 5,  str.tostring(i_sl, "#.######"),    text_color=color.red,   text_size=size.tiny)
    table.cell(tbl, 0, 6,  "1R distance",        text_color=color.silver, text_size=size.tiny)
    table.cell(tbl, 1, 6,  str.tostring(risk_r, "#.######"),  text_color=color.white, text_size=size.tiny)
    table.cell(tbl, 0, 7,  "TPs defined",        text_color=color.silver, text_size=size.tiny)
    table.cell(tbl, 1, 7,  str.tostring(n_tps),  text_color=color.white,  text_size=size.tiny)
    table.cell(tbl, 0, 8,  "Highest TP hit",     text_color=color.silver, text_size=size.tiny)
    table.cell(tbl, 1, 8,  "TP" + str.tostring(high_tp) + " / " + str.tostring(n_tps), text_color=high_tp > 0 ? color.lime : color.red, text_size=size.small)
    table.cell(tbl, 0, 9,  "Closed by",          text_color=color.silver, text_size=size.tiny)
    table.cell(tbl, 1, 9,  rsn_str(close_rsn),   text_color=color.white,  text_size=size.tiny)
    table.cell(tbl, 0, 10, "Realised PnL",       text_color=color.silver, text_size=size.small)
    table.cell(tbl, 1, 10, str.tostring(math.round(realised, 3)) + "R", text_color=pnl_col, text_size=size.normal)
    table.cell(tbl, 0, 11, "Remaining pos",      text_color=color.silver, text_size=size.tiny)
    table.cell(tbl, 1, 11, str.tostring(math.round(remaining * 100, 1)) + "%", text_color=color.white, text_size=size.tiny)
    table.cell(tbl, 0, 12, "Bars held",          text_color=color.silver, text_size=size.tiny)
    table.cell(tbl, 1, 12, str.tostring(bar_index - entry_bar), text_color=color.white, text_size=size.tiny)
